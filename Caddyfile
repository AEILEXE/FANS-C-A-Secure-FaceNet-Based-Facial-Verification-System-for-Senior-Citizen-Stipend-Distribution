# FANS-C — Caddy Reverse Proxy Configuration
# ===========================================
# Caddy terminates HTTPS on the barangay LAN and forwards plain HTTP to
# Waitress (Django) listening on 127.0.0.1:8000.
#
# WHY THIS IS NEEDED:
#   Browsers only allow webcam access (getUserMedia) from a "secure context" —
#   that means https:// or localhost.  A plain http://192.168.x.x URL blocks
#   the camera on every client device.  Caddy + a locally-trusted certificate
#   from mkcert fixes this without any insecure browser flags.
#
# ─────────────────────────────────────────────────────────────────────────────
# FILES THAT MUST EXIST BEFORE RUNNING CADDY
# ─────────────────────────────────────────────────────────────────────────────
# Place these two certificate files in the SAME FOLDER as this Caddyfile
# (i.e. the project root, D:\FANS\...\):
#
#   fans-barangay.local+3.pem       ← TLS certificate (public)
#   fans-barangay.local+3-key.pem   ← TLS private key (keep secret, no git)
#
# Generate them with mkcert (run ONCE per server machine):
#
#   Step 1 — Install the local CA into Windows trust store (run as Admin):
#     mkcert -install
#
#   Step 2 — Issue the certificate (run from the project root folder):
#     mkcert fans-barangay.local 192.168.1.77 localhost 127.0.0.1
#
#   Replace 192.168.1.77 with your server's actual LAN IP (run `ipconfig`).
#   The "+3" suffix in the filename means the cert covers all four names.
#
# ─────────────────────────────────────────────────────────────────────────────
# HOW TO START THE SYSTEM (two PowerShell windows on the server machine)
# ─────────────────────────────────────────────────────────────────────────────
#
# Window 1 — Start Waitress (Django WSGI server):
#   cd D:\FANS\<project-folder>
#   .\.venv\Scripts\activate
#   waitress-serve --listen=127.0.0.1:8000 fans.wsgi:application
#
# Window 2 — Start Caddy (from the same project folder):
#   caddy run --config Caddyfile
#
# Caddy MUST be run from the folder that contains this Caddyfile so that
# the relative certificate paths below resolve correctly.
#
# ─────────────────────────────────────────────────────────────────────────────
# CLIENT DEVICE SETUP (do once per device on the LAN)
# ─────────────────────────────────────────────────────────────────────────────
# Each client device needs two things:
#
#   1. HOSTS FILE entry — maps fans-barangay.local to the server's LAN IP:
#      Windows: C:\Windows\System32\drivers\etc\hosts
#      Add this line (replace IP with your server's actual LAN IP):
#        192.168.1.77  fans-barangay.local
#
#   2. TRUSTED CA — install the mkcert root certificate so the browser
#      shows a padlock instead of a security warning.
#      On the server machine, run:
#        mkcert -CAROOT
#      Copy the rootCA.pem file from that folder to each client device.
#      On Windows clients: double-click rootCA.pem → Install Certificate →
#        Local Machine → Trusted Root Certification Authorities.
#
# After both steps, open https://fans-barangay.local in the browser.
# The camera will work and no certificate warning will appear.
#
# ─────────────────────────────────────────────────────────────────────────────
# DJANGO .env SETTINGS REQUIRED FOR HTTPS (add to .env on the server)
# ─────────────────────────────────────────────────────────────────────────────
#   DEBUG=False
#   ALLOWED_HOSTS=fans-barangay.local,192.168.1.77,localhost,127.0.0.1
#   CSRF_TRUSTED_ORIGINS=https://fans-barangay.local
#   SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
#   USE_X_FORWARDED_HOST=True
#
# ─────────────────────────────────────────────────────────────────────────────
# FIREWALL (run once as Administrator on the server)
# ─────────────────────────────────────────────────────────────────────────────
#   netsh advfirewall firewall add rule ^
#     name="FANS-C Caddy HTTPS" ^
#     dir=in action=allow protocol=TCP localport=443
#
#   Port 8000 does NOT need a firewall rule — Waitress binds to 127.0.0.1
#   (loopback only) so it is never reachable from outside the server machine.
# ─────────────────────────────────────────────────────────────────────────────

fans-barangay.local {
    # TLS: use the locally-issued mkcert certificate and private key.
    # Paths are relative to the current working directory when caddy is started.
    # Both files must be present before running `caddy run --config Caddyfile`.
    tls fans-barangay.local+3.pem fans-barangay.local+3-key.pem

    # Forward all HTTPS requests to Waitress (Django) on the loopback address.
    # Waitress must already be running before Caddy starts serving requests.
    reverse_proxy 127.0.0.1:8000 {
        # Tell Django the original request arrived over HTTPS.
        # Django reads this via SECURE_PROXY_SSL_HEADER in settings.py so that
        # session cookies, CSRF cookies, and redirect URLs all use https://.
        header_up X-Forwarded-Proto https

        # Pass the real client IP to Django's audit log.
        header_up X-Real-IP {remote_host}
    }
}
