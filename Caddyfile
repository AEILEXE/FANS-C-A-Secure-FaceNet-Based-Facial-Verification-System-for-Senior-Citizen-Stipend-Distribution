# FANS-C -- Caddy Reverse Proxy Configuration
# Caddy terminates HTTPS on the barangay LAN and proxies plain HTTP to
# Django/Waitress on 127.0.0.1:8000.
#
# Start from the project root:
#   caddy run --config Caddyfile
#
# cert files must exist in the same folder as this Caddyfile:
#   fans-cert.pem         TLS certificate (public)
#   fans-cert-key.pem     TLS private key  (keep secret, never commit)
#
# Generated by setup-secure-server.ps1 (run once per machine).
# Regenerate: setup-secure-server.ps1 -ForceRegenerateCert

{
    # Disable built-in admin API -- not used; prevents port 2019 conflicts on restart.
    admin off
}

fans-barangay.local {
    # TLS: use the stable mkcert certificate.
    # Paths are relative to the Caddy process working directory (always the project root).
    tls fans-cert.pem fans-cert-key.pem

    # Proxy all HTTPS traffic to Django on loopback.
    reverse_proxy 127.0.0.1:8000 {
        # Tell Django the original request came over HTTPS.
        # Required for CSRF cookies, Secure flag, and redirect URLs.
        # Django reads this via SECURE_PROXY_SSL_HEADER = ("HTTP_X_FORWARDED_PROTO", "https").
        header_up X-Forwarded-Proto https
    }
}
