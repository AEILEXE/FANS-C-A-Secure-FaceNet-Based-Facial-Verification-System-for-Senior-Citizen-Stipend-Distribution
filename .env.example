# ============================================================
# FANS-C Environment Configuration Template
# ============================================================
# HOW TO USE:
#   setup.ps1 copies this file to .env automatically.
#   You can also copy it manually:
#     Copy-Item .env.example .env
#
# NEVER commit .env to git — it contains secrets.
#
# HOW TO GENERATE THE ENCRYPTION KEY:
#   python manage.py generate_key
#   Copy the output into EMBEDDING_ENCRYPTION_KEY below.
#
#   WARNING: If this key is lost or changed, all stored face
#   embeddings become permanently unreadable and beneficiaries
#   must re-register from scratch.
#
# MULTI-DEVICE SETUP:
#   All workstations that share the same central database MUST
#   use the same EMBEDDING_ENCRYPTION_KEY.  Transfer the .env
#   file securely (USB, encrypted message) — never plain email.
# ============================================================

# ── Django Core ────────────────────────────────────────────
# Generate a unique key: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=#01%um+1st+@c)jg1fx0t+pi^6jj#wd9uxmm3q)j(zk^&p166b

# Local development:
#   DEBUG=True, ALLOWED_HOSTS=localhost,127.0.0.1
#
# Barangay LAN server -- plain HTTP (camera blocked on client devices):
#   DEBUG=False, ALLOWED_HOSTS=192.168.1.77,localhost,127.0.0.1
#
# Barangay LAN server -- secure HTTPS via Caddy (recommended):
#   DEBUG=False, ALLOWED_HOSTS=fans-barangay.local,192.168.1.77,localhost,127.0.0.1
#   Also set CSRF_TRUSTED_ORIGINS and SECURE_PROXY_SSL_HEADER below.
#   Browsers require HTTPS (secure context) for webcam / getUserMedia access.
#   A plain http:// LAN URL will block camera capture on client devices.
#
# Comma-separated. Whitespace around commas is stripped automatically.
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ───────────────────────────────────────────────
# Local / standalone:    USE_SQLITE=True  (no PostgreSQL needed)
# Centralized server:    USE_SQLITE=False (all clients share one PostgreSQL DB)
USE_SQLITE=True

# PostgreSQL settings — used when USE_SQLITE=False.
# For centralized deployment: set DB_HOST to the server's IP or hostname.
DB_NAME=fans_db
DB_USER=fans_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# Connection pooling — keep DB connections alive between requests.
# Set to 60 (seconds) for centralized PostgreSQL deployment.
# Set to 0 to close the connection after every request (SQLite default).
CONN_MAX_AGE=0

# ── Face Embedding Security ────────────────────────────────
# REQUIRED. Generate with:  python manage.py generate_key
# Keep this secret and back it up securely.
# Changing this key makes all stored embeddings unreadable.
EMBEDDING_ENCRYPTION_KEY= S-qXxPWmuyKzrh4c_pToYqIVM50_WmdUavd9vSwTGnk=

# ── Face Matching Thresholds ───────────────────────────────
# DEMO_MODE=True   Assisted Rollout Mode — uses DEMO_THRESHOLD (0.60).
#                  Liveness is recorded but does NOT block verification.
#                  Use this during gradual deployment to collect data.
# DEMO_MODE=False  Strict Mode — uses VERIFICATION_THRESHOLD (0.75).
#                  Enable only after validating performance on your hardware.
DEMO_MODE=True
DEMO_THRESHOLD=0.60
VERIFICATION_THRESHOLD=0.75

# Max face-scan retries before the fallback ID-check path is offered (default 2)
MAX_RETRY_ATTEMPTS=2

# ── Liveness Settings ──────────────────────────────────────
# LIVENESS_REQUIRED=False  Assisted Rollout Mode: liveness is logged but
#                          never blocks verification. Recommended during rollout.
# LIVENESS_REQUIRED=True   Strict Mode: a failed liveness check denies
#                          the verification. Enable in full production.
LIVENESS_REQUIRED=False

# Anti-spoofing texture score threshold (0.0-1.0).
# 0.15 is permissive for browser/webcam captures.
# Raise to 0.30-0.50 in production with a trained anti-spoofing CNN.
ANTI_SPOOF_THRESHOLD=0.15

# ── Media Files ────────────────────────────────────────────
MEDIA_ROOT=media

# ── Reverse-Proxy / HTTPS (centralized server deployment) ──
# Leave all three empty for local development -- they are no-ops when unset.
#
# For barangay LAN deployment behind Caddy with HTTPS using fans-barangay.local:
#
#   CSRF_TRUSTED_ORIGINS=https://fans-barangay.local
#     Required: Caddy terminates TLS and forwards plain HTTP to Django.
#     Django sees plain HTTP internally but browsers send from an https://
#     origin.  Without this, all form POSTs (login, verification, register)
#     are rejected with HTTP 403 Forbidden.
#
#   SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
#     Tells Django to trust the X-Forwarded-Proto header that Caddy sets.
#     This makes SESSION_COOKIE_SECURE and CSRF_COOKIE_SECURE work correctly
#     even though Django itself receives plain HTTP from Caddy.
#
#   USE_X_FORWARDED_HOST=True
#     Use the Host header forwarded by Caddy (fans-barangay.local) rather
#     than the internal address (127.0.0.1:8000).
#
# For raw-IP HTTPS (less preferred, harder to get certs for):
#   CSRF_TRUSTED_ORIGINS=https://192.168.1.77
#
CSRF_TRUSTED_ORIGINS=
SECURE_PROXY_SSL_HEADER=
USE_X_FORWARDED_HOST=False

# ── Secure-cookie mode ──────────────────────────────────────
# Controls whether the Secure flag is set on session and CSRF cookies.
#
#   Default (no entry here):
#     DEBUG=True  → cookies work over http:// (fine for local dev)
#     DEBUG=False → cookies are HTTPS-only (intended for production)
#
#   SECURE_COOKIES=True   Force HTTPS-only cookies regardless of DEBUG.
#   SECURE_COOKIES=False  Allow cookies over plain http://.
#
# WHY PLAIN HTTP LOGIN FAILS when DEBUG=False (and SECURE_COOKIES is unset):
#   With Secure cookies enabled, the browser will NOT send the session or
#   CSRF cookie over http://.  Any login attempt at http://192.168.x.x:8000
#   will immediately fail with:
#     Forbidden (CSRF cookie not set.): /accounts/login/
#   This is correct and expected for the production HTTPS path.
#
# To allow login over plain HTTP (e.g. for LAN IP fallback/testing):
#   Set SECURE_COOKIES=False  AND  keep the Caddy HTTPS path for normal use.
#   Do NOT use SECURE_COOKIES=False on a server exposed to untrusted networks.
#
# SECURE_COOKIES=False

# ── Offline Sync (fallback / secondary mode) ───────────────
# Offline sync is for edge deployments where workstations operate without
# a live network connection to the central server.  In the recommended
# centralized architecture, leave SYNC_API_URL empty — all clients connect
# directly to the shared PostgreSQL database through Django.
#
# The central server must use the SAME EMBEDDING_ENCRYPTION_KEY.
# Transfer it securely — if keys differ, face data will be unreadable.
#
# SYNC_API_URL example: https://central.fans-c.gov.ph/api
SYNC_API_URL=
SYNC_API_KEY=
SYNC_TIMEOUT=30
SYNC_BATCH_SIZE=50
