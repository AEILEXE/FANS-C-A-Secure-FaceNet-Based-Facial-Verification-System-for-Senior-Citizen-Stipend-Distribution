# ============================================================
# FANS-C Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains secrets.
#
# HOW TO GENERATE ENCRYPTION KEY:
#   python manage.py generate_key
#   Copy the output into EMBEDDING_ENCRYPTION_KEY below.
#   If this key is lost or changed, all stored face embeddings
#   become unreadable and beneficiaries must re-register.
# ============================================================

# Django core
SECRET_KEY=your-secret-key-here-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (SQLite is the default — fine for capstone demo)
USE_SQLITE=True

# PostgreSQL settings (only used when USE_SQLITE=False)
DB_NAME=fans_db
DB_USER=fans_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# ── Face Embedding Security ───────────────────────────────
# REQUIRED: Generate with:  python manage.py generate_key
# Keep this secret. If changed, all stored embeddings break.
EMBEDDING_ENCRYPTION_KEY=

# ── Face Matching Thresholds ──────────────────────────────
# DEMO_MODE=True  : uses DEMO_THRESHOLD (0.60), liveness non-blocking
# DEMO_MODE=False : uses VERIFICATION_THRESHOLD (0.75), stricter
DEMO_MODE=True
DEMO_THRESHOLD=0.60
VERIFICATION_THRESHOLD=0.75

# Number of retries before fallback ID check (default 2)
MAX_RETRY_ATTEMPTS=2

# ── Liveness Settings ─────────────────────────────────────
# LIVENESS_REQUIRED=False : liveness is logged but never blocks verification
# LIVENESS_REQUIRED=True  : failed liveness = verification denied (production)
LIVENESS_REQUIRED=False

# Anti-spoofing texture score threshold (0.0-1.0)
# 0.15 is permissive for webcam captures. Raise to 0.3-0.5 in production
# with a trained anti-spoofing CNN.
ANTI_SPOOF_THRESHOLD=0.15

# Media files location
MEDIA_ROOT=media
