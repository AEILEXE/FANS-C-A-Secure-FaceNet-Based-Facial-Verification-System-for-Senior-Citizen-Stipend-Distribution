# ============================================================
# FANS-C Environment Configuration Template
# ============================================================
# HOW TO USE:
#   setup.ps1 copies this file to .env automatically.
#   You can also copy it manually:
#     Copy-Item .env.example .env
#
# NEVER commit .env to git — it contains secrets.
#
# HOW TO GENERATE THE ENCRYPTION KEY:
#   python manage.py generate_key
#   Copy the output into EMBEDDING_ENCRYPTION_KEY below.
#
#   WARNING: If this key is lost or changed, all stored face
#   embeddings become permanently unreadable and beneficiaries
#   must re-register from scratch.
#
# MULTI-DEVICE SETUP:
#   All workstations that share the same central database MUST
#   use the same EMBEDDING_ENCRYPTION_KEY.  Transfer the .env
#   file securely (USB, encrypted message) — never plain email.
# ============================================================

# ── Django Core ────────────────────────────────────────────
# Generate a unique key: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=your-secret-key-here-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ───────────────────────────────────────────────
# SQLite is the default — suitable for single-workstation deployments.
USE_SQLITE=True

# PostgreSQL settings (only used when USE_SQLITE=False)
DB_NAME=fans_db
DB_USER=fans_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# ── Face Embedding Security ────────────────────────────────
# REQUIRED. Generate with:  python manage.py generate_key
# Keep this secret and back it up securely.
# Changing this key makes all stored embeddings unreadable.
EMBEDDING_ENCRYPTION_KEY=

# ── Face Matching Thresholds ───────────────────────────────
# DEMO_MODE=True   Assisted Rollout Mode — uses DEMO_THRESHOLD (0.60).
#                  Liveness is recorded but does NOT block verification.
#                  Use this during gradual deployment to collect data.
# DEMO_MODE=False  Strict Mode — uses VERIFICATION_THRESHOLD (0.75).
#                  Enable only after validating performance on your hardware.
DEMO_MODE=True
DEMO_THRESHOLD=0.60
VERIFICATION_THRESHOLD=0.75

# Max face-scan retries before the fallback ID-check path is offered (default 2)
MAX_RETRY_ATTEMPTS=2

# ── Liveness Settings ──────────────────────────────────────
# LIVENESS_REQUIRED=False  Assisted Rollout Mode: liveness is logged but
#                          never blocks verification. Recommended during rollout.
# LIVENESS_REQUIRED=True   Strict Mode: a failed liveness check denies
#                          the verification. Enable in full production.
LIVENESS_REQUIRED=False

# Anti-spoofing texture score threshold (0.0-1.0).
# 0.15 is permissive for browser/webcam captures.
# Raise to 0.30-0.50 in production with a trained anti-spoofing CNN.
ANTI_SPOOF_THRESHOLD=0.15

# ── Media Files ────────────────────────────────────────────
MEDIA_ROOT=media

# ── Offline Sync ───────────────────────────────────────────
# Leave SYNC_API_URL empty for standalone (offline-only) operation.
# When set, sync_beneficiaries will push unsynced records to this URL.
#
# The central server must use the SAME EMBEDDING_ENCRYPTION_KEY.
# Transfer it securely — if keys differ, face data will be unreadable.
#
# SYNC_API_URL example: https://central.fans-c.gov.ph/api
SYNC_API_URL=
SYNC_API_KEY=
SYNC_TIMEOUT=30
SYNC_BATCH_SIZE=50
